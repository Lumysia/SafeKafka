# =============================================================================
# Kafka / Confluent Cloud
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=pkc-XXXXX.<region>.aws.confluent.cloud:9092
KAFKA_API_KEY=your-confluent-api-key
KAFKA_API_SECRET=your-confluent-api-secret

# Set to "true" to bypass SASL and talk to a local plaintext broker (docker-compose)
USE_LOCAL_BROKER=false

# Topic names
TOPIC_FRAMES=cctv-frames
TOPIC_DETECTIONS=safety-detections
TOPIC_ALERTS=safety-alerts

# =============================================================================
# Producer
# =============================================================================
PRODUCER_CAMERA_ID=cam-01
PRODUCER_ANALYTICS_FPS=4
PRODUCER_JPEG_QUALITY=80

# =============================================================================
# Detector
# =============================================================================
DETECTOR_WEIGHTS=yolov8m.pt
# auto = MPS on Apple Silicon, CUDA on NVIDIA, otherwise CPU
DETECTOR_DEVICE=auto
DETECTOR_CONF=0.25

# =============================================================================
# Aggregator
# =============================================================================
AGG_WINDOW_SECONDS=60
AGG_UNSAFE_RATIO_ALERT=0.30
AGG_MIN_WINDOW_OBS=5

# =============================================================================
# Dashboard
# =============================================================================
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
